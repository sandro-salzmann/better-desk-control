{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "better-desk-control",
  "version": "0.1.0",
  "identifier": "com.pixelfondue.betterdeskcontrol",
  "build": {
    "beforeDevCommand": "yarn dev:js",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build:js",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Better Desk Control",
        "width": 400,
        "height": 480,
        "resizable": false,
        "maximizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
