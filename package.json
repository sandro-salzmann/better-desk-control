{
  "name": "better-desk-control",
  "private": true,
  "version": "2026.5.4",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev:js": "vite",
    "build:js": "tsc && vite build",
    "tauri": "tauri",
    "build:cli": "cargo build --release --locked -p desk-cli",
    "release": "node scripts/bump.mjs",
    "build:all": "tauri build -- --locked && yarn build:cli",
    "verify": "yarn verify:js && yarn verify:rust",
    "verify:js": "biome check",
    "verify:rust": "cargo fmt --all -- --check && cargo clippy --workspace --all-targets --locked -- -D warnings",
    "fix": "yarn fix:js && yarn fix:rust",
    "fix:js": "biome check --write",
    "fix:rust": "cargo fmt --all"
  },
  "dependencies": {
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "~2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-store": "~2",
    "@tauri-apps/plugin-updater": "~2",
    "@tauri-apps/plugin-window-state": "~2",
    "lucide-react": "^1.17.0",
    "react": "^19.1.0",
    "react-aria-components": "^1.18.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "tailwindcss": "^4.3.0",
    "tailwindcss-react-aria-components": "^2.1.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
